# PINACO Smart Advisor — Production Environment Template
# Duplicate this file to .env.production and fill in secure values before deployment.

# Node Environment
NODE_ENV="production"
PORT="4000"

# Application Base URL
APP_URL="https://advisor.pinnacle.mw"

# Security & Secrets
JWT_SECRET="GENERATE_A_64_CHAR_HEX_RANDOM_SECRET_FOR_JWT_SIGNING"
AUTH_SECRET="GENERATE_ANOTHER_RANDOM_SECRET_FOR_LEGACY_AUTH_TOKENS"
BCRYPT_ROUNDS="12"
AUTH_TOKEN_TTL_HOURS="12"

# Gemini AI API Configuration
GEMINI_API_KEY="YOUR_PRODUCTION_GOOGLE_GEMINI_API_KEY"
GEMINI_MODEL="gemini-2.0-flash"

# PostgreSQL Database Configuration
DATABASE_URL="postgres://pinaco_user:SECURE_DB_PASSWORD@pg-cluster.internal:5432/pinaco_prod?sslmode=require"
PGSSLMODE="require"
PGCONNECT_TIMEOUT_MS="5000"

# Storage Mode ('postgres' or 'file')
PSA_STORAGE_MODE="postgres"

# Cors Allowed Origins (comma separated)
CORS_ORIGIN="https://advisor.pinnacle.mw,https://admin.pinnacle.mw"

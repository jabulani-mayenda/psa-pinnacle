# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_MODEL="gemini-2.0-flash"

# AUTH_SECRET: Secret key used to sign and verify JWT auth tokens on the backend.
# Must be a long, random string in production. Minimum 32 characters recommended.
AUTH_SECRET="change-this-to-a-long-random-string-in-production"

# AUTH_TOKEN_TTL_HOURS: How many hours a login token is valid (default: 12).
AUTH_TOKEN_TTL_HOURS="12"

# VITE_API_BASE_URL: Optional frontend API target for the backend scaffold.
# Example for local development: http://localhost:4000
VITE_API_BASE_URL=""

# VITE_GEMINI_API_KEY: Optional prototype fallback only.
# Prefer GEMINI_API_KEY on the backend so the browser never receives the secret.
VITE_GEMINI_API_KEY=""

# PostgreSQL configuration. Set either DATABASE_URL or the individual PG variables.
DATABASE_URL=""
PGHOST="localhost"
PGPORT="5432"
PGDATABASE="pinaco"
PGUSER="postgres"
PGPASSWORD=""
PGSSLMODE="disable"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
